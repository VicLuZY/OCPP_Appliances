async function api(path, opts={}) {
  const res = await fetch(path, opts);
  if (!res.ok) {
    const txt = await res.text();
    throw new Error(`${res.status} ${res.statusText}: ${txt}`);
  }
  const ct = res.headers.get('content-type') || '';
  if (ct.includes('application/json')) return res.json();
  return res.text();
}

function wattsOrDash(v) { return (v === null || v === undefined) ? '—' : v; }
function fmt(n) { return (n === null || n === undefined) ? '—' : Math.round(n).toString(); }

async function refreshAll() {
  const dashStatus = document.getElementById('dashStatus');
  dashStatus.textContent = 'Loading...';
  try {
    const limStr = document.getElementById('serviceLimitInput').value.trim();
    const dashQs = limStr ? `?service_limit_w=${encodeURIComponent(limStr)}` : '';

    const [appliances, groups, effective, dash] = await Promise.all([
      api('/api/appliances'),
      api('/api/groups'),
      api('/api/caps/effective'),
      api(`/api/dashboard${dashQs}`)
    ]);

    renderAppliances(appliances, groups, effective.caps, dash.appliances);
    renderGroups(groups);
    renderTree(groups);
    renderGroupLoading(dash.groups || {});
    renderDashboard(dash);

    dashStatus.textContent = 'Updated.';
  } catch (e) {
    dashStatus.textContent = e.message;
  }
}

function renderAppliances(appliances, groups, effCaps, dashAppliances) {
  const tbody = document.querySelector('#appliancesTable tbody');
  tbody.innerHTML = '';

  const groupMembership = {};
  for (const [gid, g] of Object.entries(groups)) {
    for (const cp_id of g.appliances) {
      groupMembership[cp_id] = groupMembership[cp_id] || [];
      groupMembership[cp_id].push(gid);
    }
  }

  const ids = Object.keys(appliances).sort();
  for (const cp_id of ids) {
    const st = appliances[cp_id];
    const instW = dashAppliances && dashAppliances[cp_id] ? dashAppliances[cp_id].instant_w : null;

    const statusTxt = st.connected ? 'connected' : 'offline';
    const statusClass = st.connected ? 'ok' : 'bad';
    const groupsTxt = (groupMembership[cp_id] || []).sort().join(', ') || '—';
    const eff = effCaps[cp_id];

    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td><b>${cp_id}</b></td>
      <td class="${statusClass}">${statusTxt}</td>
      <td><b>${fmt(instW)}</b></td>
      <td>
        <input type="number" min="0" value="${st.individual_limit_watts ?? ''}"
               placeholder="none" data-cp="${cp_id}" />
        <button data-cp="${cp_id}" data-action="set">Set</button>
        <button data-cp="${cp_id}" data-action="clear">Clear</button>
      </td>
      <td>${groupsTxt}</td>
      <td><b>${wattsOrDash(eff)}</b></td>
    `;
    tbody.appendChild(tr);
  }

  tbody.querySelectorAll('button').forEach(btn => {
    btn.addEventListener('click', async () => {
      const cp = btn.getAttribute('data-cp');
      const action = btn.getAttribute('data-action');
      const input = tbody.querySelector(`input[data-cp="${cp}"]`);
      const value = (action === 'clear') ? null : (input.value === '' ? null : parseInt(input.value, 10));
      await api(`/api/appliances/${cp}/limit`, {
        method: 'PATCH',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({limit_watts: value}),
      });
      await refreshAll();
    });
  });
}

