function drawLoadChart(points) {
  const canvas = document.getElementById('loadChart');
  const ctx = canvas.getContext('2d');
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  if (!points.length) {
    ctx.fillStyle = '#444';
    ctx.font = '12px system-ui';
    ctx.fillText('No data yet.', 10, 20);
    return;
  }

  const xs = points.map(p => p.t);
  const ys = points.map(p => p.total_w);

  const minX = Math.min(...xs);
  const maxX = Math.max(...xs);
  const minY = 0;
  const maxY = Math.max(1000, Math.max(...ys));

  const padL = 45, padR = 10, padT = 10, padB = 25;
  const W = canvas.width, H = canvas.height;

  function xMap(x) {
    if (maxX === minX) return padL;
    return padL + (x - minX) * (W - padL - padR) / (maxX - minX);
  }
  function yMap(y) {
    return padT + (maxY - y) * (H - padT - padB) / (maxY - minY);
  }

  // axes
  ctx.strokeStyle = '#bbb';
  ctx.beginPath();
  ctx.moveTo(padL, padT);
  ctx.lineTo(padL, H - padB);
  ctx.lineTo(W - padR, H - padB);
  ctx.stroke();

  // labels
  ctx.fillStyle = '#444';
  ctx.font = '12px system-ui';
  ctx.fillText(`${Math.round(maxY)} W`, 6, padT + 10);
  ctx.fillText(`0 W`, 18, H - padB + 2);

  // line
  ctx.strokeStyle = '#111';
  ctx.beginPath();
  for (let i = 0; i < points.length; i++) {
    const px = xMap(points[i].t);
    const py = yMap(points[i].total_w);
    if (i === 0) ctx.moveTo(px, py);
    else ctx.lineTo(px, py);
  }
  ctx.stroke();

  const last = points[points.length - 1];
  ctx.fillStyle = '#111';
  ctx.fillText(`Now: ${Math.round(last.total_w)} W`, W - 155, padT + 12);
}

