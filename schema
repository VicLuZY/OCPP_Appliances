function renderTree(groups) {
  // Build parent map
  const parents = {};
  for (const [gid, g] of Object.entries(groups)) {
    for (const child of (g.subgroups || [])) {
      parents[child] = parents[child] || new Set();
      parents[child].add(gid);
    }
  }
  const roots = Object.keys(groups).filter(gid => !(gid in parents)).sort();

  function walk(gid, prefix) {
    const g = groups[gid];
    const limit = (g.limit_watts === null || g.limit_watts === undefined) ? '—' : g.limit_watts;
    let s = `${prefix}${gid} [limit=${limit}] (${g.name})\n`;
    const subs = (g.subgroups || []).slice().sort();
    for (let i = 0; i < subs.length; i++) {
      const last = i === subs.length - 1;
      const branch = last ? '└─ ' : '├─ ';
      s += walk(subs[i], prefix + branch);
    }
    return s;
  }

  let out = '';
  if (!roots.length) out = '(no root groups; you may have only subgroups)';
  else for (const r of roots) out += walk(r, '');
  document.getElementById('groupTree').textContent = out;
}

